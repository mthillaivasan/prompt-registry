# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# Required — JWT signing secret. Use a long random string in production.
JWT_SECRET_KEY=replace-this-with-a-secure-random-secret-at-least-32-chars

# Required — Anthropic API key. Loaded from environment only. Never hardcoded.
# Reference in documentation as [ANTHROPIC_API_KEY]
ANTHROPIC_API_KEY=your-api-key-here

# Default seed admin account (change password after first login)
# Email:    admin@promptregistry.local
# Password: ChangeMe123!
